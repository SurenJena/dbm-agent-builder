# Oracle Source Database
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1
ORACLE_SCHEMA=HR
ORACLE_USER=hr
ORACLE_PASSWORD=hr

# PostgreSQL Target Database
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=hr_target
PG_SCHEMA=hr_schema
PG_USER=postgres
PG_PASSWORD=postgres

# Migration Settings
MIGRATION_BATCH_SIZE=10000
MIGRATION_PARALLEL_WORKERS=4
MIGRATION_LOG_LEVEL=INFO
MIGRATION_OUTPUT_DIR=./output
