# =============================================================================
# Oracle to PostgreSQL Migration - Environment Variables Template
# =============================================================================
# SECURITY: Copy this file to .env and fill in real values.
#           NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Oracle Source Database
# -----------------------------------------------------------------------------
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=ORCL
ORACLE_SCHEMA=HR
ORACLE_USER=hr
ORACLE_PASSWORD=hr

# -----------------------------------------------------------------------------
# PostgreSQL Target Database
# -----------------------------------------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=hr_db
PG_SCHEMA=hr
PG_USER=postgres
PG_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Migration Settings
# -----------------------------------------------------------------------------
BATCH_SIZE=10000
MAX_WORKERS=4
LOG_LEVEL=INFO
OUTPUT_DIR=./output
LOG_DIR=./logs
